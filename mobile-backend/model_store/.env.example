# --- Veritabanı ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/audioapp

# --- Güvenlik ---
SECRET_KEY=buraya-cok-uzun-ve-gizli-bir-anahtar-yaz-degistir
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Uygulama ---
APP_NAME=AudioExtractorAPI
APP_VERSION=1.0.0
DEBUG=True

# --- Model Depolama ---
# "local" ya da "s3"
STORAGE_TYPE=local
MODELS_DIR=./models_store

# --- AWS S3 (STORAGE_TYPE=s3 ise doldur) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=eu-central-1
