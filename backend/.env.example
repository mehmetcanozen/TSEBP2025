# Server
NODE_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:1420,http://localhost:5173,http://localhost:8080

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tsebp2025?schema=public

# Auth mode:
# - local: development-friendly local password auth.
# - supabase: Supabase Auth for shared production/staging identity.
AUTH_PROVIDER=local

# Local auth only. Replace for any shared environment.
LOCAL_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
LOCAL_ACCESS_TOKEN_SECONDS=900
LOCAL_REFRESH_TOKEN_DAYS=30

# Supabase auth mode.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional. Use this only if your Supabase project still uses a symmetric JWT secret.
SUPABASE_JWT_SECRET=
# Optional. Supabase commonly uses "authenticated".
SUPABASE_JWT_AUDIENCE=authenticated
