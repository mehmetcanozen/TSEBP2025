{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Semantic Noise Suppression",
  "version": "0.1.0",
  "identifier": "com.tsebp2025.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:8080",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Semantic Noise Suppression",
        "width": 1440,
        "height": 940,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["main-capability"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    },
    "resources": {
      "../../ai/models/AudioSepHive15Cat/": "audiosep_hive15cat/",
      "../../ai/ai_runtime/config/audiosep_hive15cat_categories.yaml": "config/audiosep_hive15cat_categories.yaml",
      "../../ai/ai_runtime/config/default_profiles.json": "config/default_profiles.json",
      "./runtime/": "runtime/"
    }
  }
}
